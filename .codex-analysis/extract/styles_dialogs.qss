    padding: 0 4px;
}

/* 添加/编辑容器 */
QFrame#addPresetBox, QFrame#editContainer {
    border: 1px solid #ead5ff;
    border-radius: 12px;
    background-color: #fcfafe;
}

#editContainer {
    margin: 4px 12px 4px 12px;
}

/* 容器内的输入框 - 修正 PlainTextEdit 选择器 */
