/* ============================================
   对话框样式
   ============================================ */

/* 通用对话框 */
QDialog {
    background-color: white;
    border-radius: 12px;
}

QDialog QLabel {
    color: #424242;
    font-size: 13px;
}

QDialog QPushButton {
    min-width: 80px;
    padding: 8px 16px;
}

/* 消息框 */
QMessageBox {
    background-color: white;
}

QMessageBox QLabel {
    color: #424242;
    font-size: 14px;
}

QMessageBox QPushButton {
    min-width: 80px;
    padding: 8px 16px;
}

/* 文件对话框 */
QFileDialog {
    background-color: white;
}

/* 颜色对话框 */
QColorDialog {
    background-color: white;
}

/* 画布提示对话框 */
#canvasPromptDialog {
    background-color: white;
    border-radius: 12px;
}

#canvasPromptDialog QTextEdit {
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    padding: 12px;
    font-size: 14px;
}

#canvasPromptDialog QPushButton {
    min-width: 100px;
    padding: 10px 20px;
    font-size: 14px;
}

/* 渠道管理对话框 */
#channelManagerDialog {
    background-color: #ffffff;
}

#channelManagerDialog QLabel {
    color: #333333;
}

#channelManagerDialog QLabel#dialogTitle {
    font-size: 14px;
    font-weight: bold;
    padding: 4px 0;
}

#channelManagerDialog QLabel#dialogHint {
    color: #ff4d4f;
    font-size: 12px;
    font-weight: bold;
}

#channelManagerDialog QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border: 1px solid #ccc;
    border-radius: 4px;
    background: transparent;
}

#channelManagerDialog QCheckBox::indicator:unchecked {
    image: none;
}

#channelManagerDialog QCheckBox::indicator:checked {
    border: none;
    image: url(assits/icon_selectbox_checked.svg);
}

#channelManagerDialog QScrollArea {
    background: transparent;
    border: none;
}

#channelManagerDialog QPushButton {
    background-color: #5b7def;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 8px 24px;
    font-size: 13px;
}

#channelManagerDialog QPushButton:hover {
    background-color: #6b8dff;
}

/* ============================================
