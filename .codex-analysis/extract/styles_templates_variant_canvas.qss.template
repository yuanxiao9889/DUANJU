/* ============================================
   鐢诲竷妯″紡涓撶敤鏍峰紡
   浣跨敤 #canvasModeContainer 浣滀负鐖堕€夋嫨鍣ㄧ‘淇濇牱寮忛殧绂?
   ============================================ */

/* 鐢诲竷瀹瑰櫒 */
#canvasModeContainer #canvasContainer {
    background-color: #ffffff;
    border: none;
}

/* 鐢诲竷妯″紡椤甸潰 */
#canvasModeContainer {
    background-color: #f5f5f5;
}

/* 宸︿晶宸ュ叿闈㈡澘 */
#canvasModeContainer #toolPanel {
    background-color: #f8f9fa;
    border-right: 1px solid #e0e0e0;
    padding: 8px;
}

#canvasModeContainer #toolPanel QPushButton {
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    padding: 8px;
    min-width: 40px;
    min-height: 40px;
}

#canvasModeContainer #toolPanel QPushButton:hover {
    background-color: #e3f2fd;
    border-color: #2196f3;
}

#canvasModeContainer #toolPanel QPushButton:checked {
    background-color: #2196f3;
    color: #2196f3;
    border-color: #2196f3;
}

#canvasModeContainer #toolPanel QPushButton:disabled {
    background-color: transparent;
    color: #bdbdbd;
}

/* 鍙充晶灞炴€ч潰鏉?*/
#propertyPanel {
    background-color: #f8f9fa;
    border-left: 1px solid #e0e0e0;
    padding: 12px;
}

#propertyPanel QLabel {
    color: #424242;
    font-size: 13px;
}

#propertyPanel QSlider {
    min-height: 20px;
}

#propertyPanel QSlider::groove:horizontal {
    border: 1px solid #bdbdbd;
    height: 4px;
    background: #e0e0e0;
    border-radius: 2px;
}

#propertyPanel QSlider::handle:horizontal {
    background: #2196f3;
    border: 1px solid #1976d2;
    width: 16px;
    margin: -6px 0;
    border-radius: 8px;
}

#propertyPanel QSlider::handle:horizontal:hover {
    background: #1976d2;
}

/* 搴曢儴鍏冪礌宸ュ叿鏍?*/
#elementToolbar {
    background-color: rgba(255, 255, 255, 0.95);
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 8px 12px;
}

#elementToolbar QPushButton {
    background-color: transparent;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    padding: 6px 12px;
    font-size: 13px;
}

#elementToolbar QPushButton:hover {
    background-color: #e3f2fd;
    border-color: #2196f3;
}

#elementToolbar QPushButton:pressed {
    background-color: #bbdefb;
}

/* 鐢诲竷鍥剧墖鍏冪礌 - 鍦嗚杈圭紭 */
#canvasImage {
    border: 2px solid transparent;
    border-radius: 12px;
}

#canvasImage:hover {
    border-color: #2196f3;
}

#canvasImageSelected {
    border: 2px solid #2196f3;
}

/* 鍥剧墖搴忓彿鏍囩 - 钃濊壊鍦嗗舰鏍囩锛堝乏涓婅锛?4x24锛?*/
#canvasImageOrderLabel {
    background-color: #5B7FFF;
    color: white;
    border-radius: 12px;  /* 鍦嗚12px锛岄厤鍚?4x24灏哄褰㈡垚鍦嗗舰 */
    font-weight: 600;     /* 鍔犵矖浠ユ彁楂樺彲璇绘€?*/
    font-size: 12px;      /* 瀛楀彿12px */
    padding: 0px;         /* 鏃犲唴杈硅窛锛屽畬鍏ㄥ眳涓?*/
}

/* 鍥剧墖灏哄鏍囩 - 宸︿笅瑙掞紝鏃犺儗鏅紝甯︽枃瀛楅槾褰?*/
#canvasImageDimsLabel {
    background-color: transparent;
    color: rgba(0, 0, 0, 0.7);
    font-size: 12px;
    font-weight: 500;
    padding: 2px 4px;
}

/* 缁樺埗灞?*/
#drawingLayer {
    background-color: transparent;
}

/* 棰滆壊閫夋嫨鍣?*/
#colorPicker {
    border: 2px solid #e0e0e0;
    border-radius: 4px;
    min-width: 40px;
    min-height: 40px;
}

#colorPicker:hover {
    border-color: #2196f3;
}

/* 宸ュ叿鎻愮ず */
QToolTip {
    background-color: #424242;
    color: white;
    border: 1px solid #212121;
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 12px;
}

/* ============================================
   鐢诲竷宸ュ叿鏍忥紙椤堕儴锛? 閲嶆柊璁捐
   ============================================ */
#canvasTopToolbar {
    background-color: #ffffff;
    border-bottom: 1px solid #e5e7eb;
    padding: 8px 16px;
}

#canvasFloatingToolbar {
    background: transparent;
    border: none;
    border-radius: 14px;
}

#canvasFloatingToolbarShadowWrap {
    background: transparent;
    border: none;
}

#canvasFloatingToolbarOuter {
    background-color: #ffffff;
    border-radius: 14px;
}

#canvasFloatingToolbarSeparator {
    background: rgba(33, 33, 33, 0.2);
}

#canvasFloatingToolbarOuter QPushButton#canvasToolbarButton {
    background: transparent;
    border: 1px solid transparent;
    border-style: solid;
    border-radius: 10px;
    padding: 0px;
    margin: 0px;
    min-width: 30px;
    min-height: 30px;
}

#canvasFloatingToolbarOuter QPushButton#canvasToolbarButton:hover {
    background: transparent;
    border: 2px solid #ebecee;
    border-radius: 10px;
}

#canvasFloatingToolbarOuter QPushButton#canvasToolbarButton:focus {
    outline: none;
    border-color: transparent;
}

#canvasFloatingToolbarOuter QPushButton#themeToggleBtn {
    background: transparent;
    border: 1px solid transparent;
    border-style: solid;
    border-radius: 10px;
}

#canvasFloatingToolbarOuter QPushButton#themeToggleBtn:hover {
    background: transparent;
    border: 2px solid #ebecee;
    border-radius: 10px;
}

#canvasFloatingToolbarOuter QPushButton#themeToggleBtn:focus {
    outline: none;
    border-color: transparent;
}

#canvasToolHoverCard {
    background-color: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.25);
    border-radius: 14px;
}

#canvasToolHoverTitle {
    color: #212121;
    font-size: 16px;
    font-weight: 600;
}

#canvasToolHoverDesc {
    color: #6b7280;
    font-size: 13px;
}

#canvasToolHoverPreview {
    border-radius: 12px;
}

/* 蹇嵎閿彍鍗?*/
#shortcutMenu {
    background: transparent;
    border: none;
    padding: 0px;
    margin: 0px;
}

#shortcutMenuContainer {
    background-color: #ffffff;
    border: none;
    border-radius: 12px;
}

#shortcutMenuTitle {
    color: #111827;
    font-size: 16px;
    font-weight: 600;
}

#shortcutName {
    color: #374151;
    font-size: 14px;
}

#shortcutKey {
    background-color: #f3f4f6;
    color: #1f2937;
    font-size: 13px;
    font-weight: 500;
    font-family: "Consolas", "Monaco", monospace;
    padding: 4px 8px;
    border-radius: 4px;
    border: 1px solid #d1d5db;
}

#shortcutPlus {
    color: #9ca3af;
    font-size: 12px;
}

#shortcutMacHint {
    color: #6b7280;
    font-size: 12px;
    font-style: italic;
}

/* 宸ュ叿鏍?- 杩斿洖鎸夐挳 */
#canvasBackButton {
    background-color: #f5f5f5;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 13px;
    color: #424242;
}

#canvasBackButton:hover {
    background-color: #eeeeee;
    border-color: #bdbdbd;
}

/* 宸ュ叿鏍?- 宸ュ叿鎸夐挳锛堝彲閫変腑锛?*/
#canvasTopToolbar QPushButton[checkable="true"] {
    background-color: #f1f5f9;
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    padding: 8px;
    font-size: 13px;
    color: #475569;
}

#canvasTopToolbar QPushButton[checkable="true"]:hover {
    background-color: #e2e8f0;
    border-color: #cbd5e1;
}

#canvasTopToolbar QPushButton[checkable="true"]:checked {
    background-color: #2196f3;
    border-color: #1976d2;
    color: white;
    font-weight: bold;
}

/* 宸ュ叿鏍?- 鎾ら攢/閲嶅仛鎸夐挳 */
#canvasTopToolbar QPushButton[objectName^="btn_undo"],
#canvasTopToolbar QPushButton[objectName^="btn_redo"] {
    background-color: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 8px;
    font-size: 16px;
    color: #475569;
}

#canvasTopToolbar QPushButton[objectName^="btn_undo"]:hover,
#canvasTopToolbar QPushButton[objectName^="btn_redo"]:hover {
    background-color: #e2e8f0;
    border-color: #cbd5e1;
}

#canvasTopToolbar QPushButton[objectName^="btn_undo"]:disabled,
#canvasTopToolbar QPushButton[objectName^="btn_redo"]:disabled {
    background-color: #f1f5f9;
    color: #cbd5e1;
    border-color: #f1f5f9;
}

/* ============================================
   鐢诲竷宸ュ叿鏍忔寜閽牱寮?- 鐜颁唬鍖栬璁?
   ============================================ */

/* 鏅€氬伐鍏锋爮鎸夐挳 */
#canvasModeContainer #canvasTopToolbar QPushButton#canvasToolbarButton {
    background: transparent;
    border: none;
    border-radius: 8px;
    color: #374151;
    font-size: 14px;
    font-weight: 500;
    padding: 6px 16px;
    margin: 4px 3px;  /* 澶栬竟璺濓紝浣挎偓鍋滆儗鏅笌瀹瑰櫒杈圭紭鏈夐棿璺?*/
    min-height: 36px;
}

#canvasModeContainer #canvasTopToolbar QPushButton#canvasToolbarButton:hover {
    background: #f3f4f6;
    color: #1f2937;
}

#canvasModeContainer #canvasTopToolbar QPushButton#canvasToolbarButton:pressed {
    background: #e5e7eb;
}

/* 鍚堝苟鎸夐挳婵€娲荤姸鎬?*/
#canvasModeContainer #canvasTopToolbar QPushButton#canvasToolbarButton[merge_active="true"] {
    color: #3b82f6;
}

/* 鍗遍櫓鎸夐挳锛堟竻绌猴級 */
#canvasModeContainer #canvasTopToolbar QPushButton#canvasToolbarButtonDanger {
    background: transparent;
    border: none;
    border-radius: 8px;
    padding: 6px 16px;
    margin: 4px 3px;  /* 澶栬竟璺濓紝浣挎偓鍋滆儗鏅笌瀹瑰櫒杈圭紭鏈夐棿璺?*/
    font-size: 14px;
    font-weight: 500;
    color: #ef4444;
    min-height: 36px;
}

#canvasModeContainer #canvasTopToolbar QPushButton#canvasToolbarButtonDanger:hover {
    background: #fef2f2;
    color: #dc2626;
}

#canvasModeContainer #canvasTopToolbar QPushButton#canvasToolbarButtonDanger:pressed {
    background: #fee2e2;
}

/* 鍥炬爣鎸夐挳锛堟挙閿€/閲嶅仛锛?*/
#canvasModeContainer #canvasTopToolbar QPushButton#canvasToolbarIconButton {
    background: transparent;
    border: none;
    border-radius: 8px;
    padding: 6px;
    margin: 4px 3px;  /* 澶栬竟璺濓紝浣挎偓鍋滆儗鏅笌瀹瑰櫒杈圭紭鏈夐棿璺?*/
    font-size: 18px;
    color: #6b7280;
    min-width: 36px;
    min-height: 36px;
}

#canvasModeContainer #canvasTopToolbar QPushButton#canvasToolbarIconButton:hover {
    background: #f3f4f6;
    color: #374151;
}

#canvasModeContainer #canvasTopToolbar QPushButton#canvasToolbarIconButton:pressed {
    background: #e5e7eb;
}

#canvasModeContainer #canvasTopToolbar QPushButton#canvasToolbarIconButton:disabled {
    color: #d1d5db;
    background: transparent;
}

/* 鐢诲竷渚ц竟鏍?- 娴姩闈㈡澘鏍峰紡锛堝簳閮ㄥ眳涓級 */
#canvasSidebar {
    background-color: transparent;
    border: none;
}

/* 渚ц竟鏍忔爣棰?*/
#sidebarTitle {
    font-size: 18px;
    font-weight: bold;
    color: #64748b;
}

/* 渚ц竟鏍忓叧闂寜閽?*/
#sidebarCloseButton {
    background: transparent;
    border: none;
    border-radius: 16px;
    font-size: 18px;
    color: #64748b;
}

#sidebarCloseButton:hover {
    background: #f1f5f9;
    color: #64748b;
}

/* 渚ц竟鏍忔彁绀烘枃瀛?*/
#sidebarHint {
    color: #64748b;
    font-size: 12px;
    padding: 4px;
}

/* 鍙傝€冨浘鐗囨暟閲忔爣绛?*/
#referenceCountLabel {
    color: #64748b;
    font-size: 13px;
    padding: 8px;
    background: #f8fafc;
    border-radius: 4px;
}

/* 渚ц竟鏍忕敓鎴愭寜閽?*/
#sidebarGenerateButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #e83ed5, stop:1 #fd952d);
    border: none;
    border-radius: 6px;
    padding: 12px;
    font-size: 14px;
    color: white;
    font-weight: bold;
}

#sidebarGenerateButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #e83ed5, stop:1 #fd952d);
}

#sidebarGenerateButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #e83ed5, stop:1 #fd952d);
}

/* 灞炴€ч潰鏉挎彁绀轰俊鎭?*/
#propertyInfo {
    color: #64748b;
    font-size: 14px;
    padding: 20px;
    background: #f8fafc;
    border-radius: 8px;
}

/* 鎷煎悎棰勮瀵硅瘽妗?*/
#mergePreviewDialog {
    background-color: #ffffff;
}

#mergePreviewDialog QLabel {
    color: #424242;
    font-size: 13px;
}

/* 瑁佸垏瀵硅瘽妗?*/
#cropDialog {
    background-color: #ffffff;
}

#cropDialog QPushButton {
    min-width: 80px;
    padding: 6px 12px;
}

/* ===== 鍥剧墖娴姩宸ュ叿鏍?===== */

/* 宸ュ叿鏍忓鍣?- 鐧借壊鑳屾櫙锛屾煍鍜岄槾褰?*/
#imageFloatingToolbar,
QWidget#modernFloatingToolbar {
    background-color: #ffffff;
    border: none;
    border-radius: 10px;
}

/* 宸ュ叿鎸夐挳 - 鏃犲妗嗭紝绠€娲佹牱寮忥紙绱у噾璁捐锛?*/
#imageFloatingToolbar QPushButton,
QWidget#modernFloatingToolbar QPushButton#modernIconButton {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 6px 6px;
    color: #424242;
    font-size: 13px;
    text-align: left;
}

#imageFloatingToolbar QPushButton:hover,
QWidget#modernFloatingToolbar QPushButton#modernIconButton:hover {
    background-color: rgba(0, 0, 0, 0.04);
}

#imageFloatingToolbar QPushButton:checked,
QWidget#modernFloatingToolbar QPushButton#modernIconButton:checked {
    background-color: rgba(33, 150, 243, 0.08);
    color: #2196f3;
    font-weight: 500;
}

#imageFloatingToolbar QPushButton:pressed,
QWidget#modernFloatingToolbar QPushButton#modernIconButton:pressed {
    background-color: rgba(0, 0, 0, 0.08);
}

/* ============================================
   鐢诲竷渚ц竟鏍忔牱寮?
   ============================================ */

/* 渚ц竟鏍忓鍣?*/
QWidget#sidebarContainer {
    background: white;
    border: none;
    border-radius: 12px;
}

/* 灞曞紑鎸夐挳鏍峰紡澧炲己 (澶嶇敤 sidebarContainer ID) */
QPushButton#sidebarContainer {
    background: white;
    border: none;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
    color: #64748b;
    font-weight: 600;
    text-align: center;
}

QPushButton#sidebarContainer:hover {
    background: #f8fafc;
    color: #475569;
}

QPushButton#sidebarContainer:pressed {
    background: #f1f5f9;
    color: #334155;
}

/* 渚ц竟鏍忔粴鍔ㄥ尯鍩?*/
QScrollArea#sidebarScrollArea {
    border: none;
    background: transparent;
}

QScrollArea#sidebarScrollArea QWidget {
    background: transparent;
}

QScrollArea#sidebarScrollArea QScrollBar:vertical {
    background: #f1f5f9;
    width: 8px;
    border-radius: 4px;
    margin: 0;
}

QScrollArea#sidebarScrollArea QScrollBar::handle:vertical {
    background: #cbd5e1;
    border-radius: 4px;
    min-height: 30px;
}

QScrollArea#sidebarScrollArea QScrollBar::handle:vertical:hover {
    background: #94a3b8;
}

QScrollArea#sidebarScrollArea QScrollBar::add-line:vertical,
QScrollArea#sidebarScrollArea QScrollBar::sub-line:vertical {
    height: 0px;
}

/* 渚ц竟鏍忔爣棰樺浘鏍?*/
QLabel#sidebarTitleIcon {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #e83ed5, stop:1 #fd952d);
    border-radius: 8px;
    font-size: 16px;
}

/* 渚ц竟鏍忔爣棰?*/
QLabel#sidebarTitle {
    font-size: 16px;
    font-weight: 600;
    color: #64748b;
}

/* 渚ц竟鏍忔爣绛?*/
QLabel#sidebarLabel {
    font-size: 13px;
    font-weight: 500;
    color: #64748b;
}

/* 渚ц竟鏍忔枃鏈緭鍏ユ */
QWidget#sidebarContainer QTextEdit#sidebarTextEdit {
    background-color: #f8f9fa !important;
    background: #f8f9fa !important;
    border: 1px solid #e9ecef !important;
    border-radius: 8px !important;
    padding: 16px !important;
    font-size: 14px !important;
    color: #1e293b !important;
    min-height: 120px !important;
}

QWidget#sidebarContainer QTextEdit#sidebarTextEdit:focus {
    border: 2px solid #d1d5db !important;
    background-color: #f8f9fa !important;
    background: #f8f9fa !important;
    outline: 4px solid rgba(209, 213, 219, 0.3);
    outline-offset: 0px;
}

/* 渚ц竟鏍忎笅鎷夋 */
QWidget#sidebarContainer QComboBox#sidebarComboBox {
    background-color: #f8f9fa !important;
    background: #f8f9fa !important;
    border: 1px solid #e9ecef !important;
    border-radius: 8px !important;
    padding: 8px 12px !important;
    font-size: 14px !important;
    color: #1e293b !important;
    min-height: 36px !important;
    max-height: 44px !important;
}

QWidget#sidebarContainer QComboBox#sidebarComboBox:hover {
    border: 1px solid #cbd5e1 !important;
}

QWidget#sidebarContainer QComboBox#sidebarComboBox:focus {
    border: 2px solid #d1d5db !important;
    background-color: #f8f9fa !important;
    background: #f8f9fa !important;
    outline: 4px solid rgba(209, 213, 219, 0.3);
    outline-offset: 0px;
}

QComboBox#sidebarComboBox::drop-down {
    border: none;
    width: 30px;
    background: transparent;
}

QComboBox#sidebarComboBox::down-arrow {
    /* 绉婚櫎鑷畾涔夌澶达紝浣跨敤 ModernIconComboBox 鐨勫浘鏍?*/
    image: none;
    width: 0px;
    height: 0px;
}

QComboBox#sidebarComboBox QAbstractItemView {
    background: #f8f9fa;
    border: 1px solid #e9ecef;
    border-radius: 4px;
    selection-background-color: #e9ecef;
    selection-color: #64748b;
    padding: 8px;
    outline: none;
}

QComboBox#sidebarComboBox QAbstractItemView::item {
    padding: 12px 16px;
    min-height: 40px;
    border-radius: 4px;
    background: transparent;
}

QComboBox#sidebarComboBox QAbstractItemView::item:selected {
    background: #e9ecef;
    color: #64748b;
}

QComboBox#sidebarComboBox QAbstractItemView::item:hover {
    background: #e9ecef;
}

/* 渚ц竟鏍忔暟瀛楄緭鍏ユ */
QWidget#sidebarContainer QSpinBox#sidebarSpinBox {
    background-color: #f8f9fa !important;
    background: #f8f9fa !important;
    border: 1px solid #e9ecef !important;
    border-radius: 8px !important;
    padding: 8px 12px !important;
    font-size: 14px !important;
    color: #1e293b !important;
    min-height: 36px !important;
    max-height: 44px !important;
}

QWidget#sidebarContainer QSpinBox#sidebarSpinBox:hover {
    border: 1px solid #cbd5e1 !important;
}

QWidget#sidebarContainer QSpinBox#sidebarSpinBox:focus {
    border: 2px solid #d1d5db !important;
    background-color: #f8f9fa !important;
    background: #f8f9fa !important;
    outline: 4px solid rgba(209, 213, 219, 0.3);
    outline-offset: 0px;
}

QSpinBox#sidebarSpinBox::up-button,
QSpinBox#sidebarSpinBox::down-button {
    background: transparent;
    border: none;
    width: 24px;
}

