}
#presetItemWidget[separator="true"] {
    border-bottom: 1px solid #404040;
}
#presetItemWidget[active="true"] {
    background-color: #3a3a3a;
    border-bottom: none;
}

/* 预设操作按钮 (编辑/删除/查看) */
QPushButton#presetActionBtn {
