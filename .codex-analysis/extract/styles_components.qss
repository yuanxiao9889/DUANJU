/* 现代化复选框样式 */
QCheckBox {
    spacing: 8px;
    font-size: 13px;
    color: #575a5e;
}

QCheckBox:disabled {
    color: #acadaf;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #E5E7EB;
    border-radius: 4px;
    background-color: #FFFFFF;
}

QCheckBox::indicator:unchecked {
    image: none;
}

QCheckBox::indicator:hover {
    border-color: #7B8CFF;
}

QCheckBox::indicator:checked {
    background-color: #7B8CFF;
    border: 2px solid #7B8CFF;
    image: url(assits/icon_confirm_white.svg);
}

QCheckBox::indicator:disabled {
    background-color: #F3F4F6;
    border-color: #E5E7EB;
}

/* 特定ID的复选框应用样式 */
#savePromptCheckbox,
#autoSaveCheckbox,
#appSettingsCheckbox,
#presetCheckbox {
    /* 继承上述通用样式 */
}

#presetCheckbox {
    spacing: 0px;
    padding: 0px;
    margin: 0px;
}

#appSettingsCheckbox::indicator:checked,
#presetCheckbox::indicator:checked {
    background-color: #000000;
    border: 2px solid #000000;
    image: url(assits/icon_confirm_white.svg);
}

/* ============================================
   设置对话框 - Tab 与目录选择样式（浅色主题）
