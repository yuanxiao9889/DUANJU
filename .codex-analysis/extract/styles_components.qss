/* ============================================
   模式切换组件样式
   ============================================ */

/* 模式切换容器 - 浅灰色圆角底框 */
QWidget#modeSwitchContainer {
    background: #f1f5f9;  /* 浅灰色底 */
    border: none;
    border-radius: 20px;
    /* padding 在 Python 代码中通过 setContentsMargins 设置 */
}

/* 模式切换按钮 - 通用样式 */
QPushButton#modeSwitchBtn {
    background: transparent;
    color: #64748b;
    border: none;
    padding: 3px 8px;  /* 按钮内部间距 */
    font-size: 15px;  /* 加大字号 */
    font-weight: 500;
    min-width: 100px;
    min-height: 38px;  /* 增加高度 */
}

/* 左侧按钮圆角 */
QPushButton#modeSwitchBtn[position="left"] {
    border-radius: 20px;  /* 增大圆角 */
    margin-right: 1px;  /* 减小间距 */
}

/* 右侧按钮圆角 */
QPushButton#modeSwitchBtn[position="right"] {
    border-radius: 20px;  /* 增大圆角 */
    margin-left: 1px;  /* 减小间距 */
}

/* 选中状态 - 白色圆角底 */
QPushButton#modeSwitchBtn:checked {
    background: #FFFFFF;
    color: #1f2937;
    font-weight: 600;
    border: none;
}


/* 按下状态（未选中） */
QPushButton#modeSwitchBtn:pressed:!checked {
    background: rgba(255, 255, 255, 0.8);
}

