    border-bottom: none;
}

/* 预设操作按钮 (编辑/删除/查看) */
QPushButton#presetActionBtn {
    background-color: transparent;
    border: none;
    border-radius: 4px;
}
QPushButton#presetActionBtn:hover {
    background-color: rgba(0, 0, 0, 0.05);
}

#presetDisplay {
    background-color: transparent;
    border: none;
}

/* 区域标题 */
QLabel#sectionTitle {
    font-size: 16px;
    font-weight: bold;
    color: #374151;
}

/* 添加预设标题 */
QLabel#addPresetHeader {
    color: #e83ed5;
    font-weight: bold;
    font-size: 16px;
}

/* 滚动区域 */
QScrollArea#quickTagScrollArea {
    background: transparent;
    border: none;
}

/* 列表容器 */
QWidget#quickTagListContainer {
    background-color: transparent;
}

/* 小文本按钮 (全部展开/折叠) */
QPushButton#smallTextBtn {
    border-radius: 4px;
    padding: 0 8px;
    background-color: transparent;
    color: #acadaf;
    border: 1px solid transparent;
}
QPushButton#smallTextBtn[compact="true"] {
    padding: 0 4px;
    min-width: 0;
}
QPushButton#smallTextBtn:hover {
    background-color: #F3F4F6;
    color: #374151;
}

/* 设置按钮 */
QPushButton#quickTagSettingBtn {
    border: none;
    background: transparent;
    border-radius: 4px;
}

QPushButton#quickTagSettingBtn:hover {
    background: rgba(0, 0, 0, 0.05);
}

QPushButton#quickTagSettingBtn:pressed {
    background: rgba(0, 0, 0, 0.08);
}

QPushButton#quickTagExpandBtn {
    border: none;
    background: transparent;
    border-radius: 4px;
}

QPushButton#quickTagExpandBtn:hover {
    background: rgba(0, 0, 0, 0.05);
}

QPushButton#quickTagExpandBtn:pressed {
    background: rgba(0, 0, 0, 0.08);
}

/* API config component */
QWidget#apiConfigWidget QLabel#apiConfigTitle {
    color: #575a5e;
}

QWidget#apiConfigWidget QLabel#apiCfgKeyLabel,
QWidget#apiConfigWidget QLabel#apiCfgAccountTitle {
    color: #b0b0b0;
}

QWidget#apiConfigWidget QLabel#apiCfgKeySummary,
QWidget#apiConfigWidget QLabel#apiCfgAccountMeta {
    color: #6B7280;
}

QWidget#apiConfigWidget QLabel#apiCfgAccountTitle,
QWidget#apiConfigWidget QLabel#apiCfgAccountName,
QWidget#apiConfigWidget QLabel#apiCfgAccountMeta {
    font-size: 16px;
}

QWidget#apiConfigWidget QLabel#apiCfgAccountName {
    color: #1f2937;
    font-weight: 600;
}

QWidget#apiConfigWidget QLabel#apiCfgAccountRoleBadge {
    color: #475569;
    background-color: #F8FAFC;
    border: 1px solid #CBD5E1;
    border-radius: 2px;
    padding: 2px 8px;
    font-size: 13px;
    font-weight: 500;
}

QWidget#apiConfigWidget QLabel#apiCfgAccountRoleBadge[accountRole="enterprise"] {
    color: #059669;
    background-color: #ECFDF5;
    border: 1px solid #A7F3D0;
}

QWidget#apiConfigWidget QLabel#apiCfgAccountRoleBadge[accountRole="agent"],
QWidget#apiConfigWidget QLabel#apiCfgAccountRoleBadge[accountRole="admin"] {
    color: #EA580C;
    background-color: #FFF7ED;
    border: 1px solid #FED7AA;
}

QWidget#apiConfigWidget QPushButton#apiCfgExpandBtn,
QWidget#apiConfigWidget QPushButton#apiCfgUsageBtn,
QWidget#apiConfigWidget QPushButton#apiCfgUsageHistoryBtn {
    background: transparent;
    border: none;
    border-radius: 0px;
    padding: 0px;
}

QWidget#apiConfigWidget QPushButton#apiCfgExpandBtn:hover,
QWidget#apiConfigWidget QPushButton#apiCfgUsageBtn:hover,
QWidget#apiConfigWidget QPushButton#apiCfgUsageHistoryBtn:hover,
QWidget#apiConfigWidget QPushButton#apiCfgExpandBtn:pressed,
QWidget#apiConfigWidget QPushButton#apiCfgUsageBtn:pressed,
QWidget#apiConfigWidget QPushButton#apiCfgUsageHistoryBtn:pressed {
    background: transparent;
    border: none;
}

QWidget#apiConfigWidget QPushButton#apiCfgManageModelsBtn,
QWidget#apiConfigWidget QPushButton#toggleBtn {
    background-color: #ffffff;
    border: 1px solid #d7dbe2;
    border-radius: 8px;
}

QWidget#apiConfigWidget QPushButton#apiCfgManageModelsBtn:hover,
QWidget#apiConfigWidget QPushButton#toggleBtn:hover {
    background-color: #f8fafc;
}

QWidget#apiConfigWidget QPushButton#apiCfgManageModelsBtn:pressed,
QWidget#apiConfigWidget QPushButton#toggleBtn:pressed {
    background-color: #f1f5f9;
}

QWidget#apiConfigWidget QPushButton#clearBtn,
QWidget#apiConfigWidget QPushButton#cancelEditBtn {
    background-color: #ffffff;
    border: 1px solid #d7dbe2;
    border-radius: 18px;
    padding: 0px 8px !important;
    margin: 0px !important;
    color: #000000;
    font-weight: 400;
    font-size: 13px;
}

QWidget#apiConfigWidget QPushButton#clearBtn:hover,
QWidget#apiConfigWidget QPushButton#cancelEditBtn:hover {
    background-color: #f8fafc;
}

QWidget#apiConfigWidget QPushButton#clearBtn:pressed,
QWidget#apiConfigWidget QPushButton#cancelEditBtn:pressed {
    background-color: #f1f5f9;
}

QWidget#apiConfigWidget QPushButton#saveBtn {
    border: none;
    border-radius: 18px;
    padding: 0px 8px !important;
    margin: 0px !important;
    color: #FFFFFF;
    font-size: 13px;
}

QWidget#apiConfigWidget QPushButton#saveBtn[authMode="api_token"] {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #e83ed5, stop:1 #fd952d);
}

QWidget#apiConfigWidget QPushButton#saveBtn[authMode="api_token"]:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #ed58dc, stop:1 #fda553);
}

QWidget#apiConfigWidget QPushButton#saveBtn[authMode="api_token"]:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #d936c3, stop:1 #f1871f);
}

QWidget#apiConfigWidget QPushButton#saveBtn[authMode="user_account"] {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #B44AE6, stop:0.45 #E24CCB, stop:1 #FF6A1F);
    font-weight: 700;
}

QWidget#apiConfigWidget QPushButton#saveBtn[authMode="user_account"]:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #BD58EA, stop:0.45 #EA5DD1, stop:1 #FF7A35);
}

QWidget#apiConfigWidget QPushButton#saveBtn[authMode="user_account"]:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #A63FDC, stop:0.45 #D642BE, stop:1 #F45E16);
}

QWidget#apiConfigWidget QPushButton#saveBtn[authMode="user_account"]:disabled {
    background: #E7E2DE;
    color: #B2AAA4;
}

/* ============================================
   快速标签管理组件样式 (QuickTagManager)
   ============================================ */

/* 样式已迁移至 dialogs.qss */
