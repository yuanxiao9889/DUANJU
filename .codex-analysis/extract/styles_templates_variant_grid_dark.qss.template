/* ============================================
   暗色主题 - 网格模式专用样式
   使用 #gridModeContainer 作为父选择器确保样式隔离
   ============================================ */

/* ============================================
   网格模式 - QSpinBox 样式
   ============================================ */
#gridModeContainer QSpinBox {
    border: 2px solid #404040;
    border-radius: 12px;
    padding: 10px 15px;
    background: #1a1a1a;
    font-size: 14px;
    font-weight: 500;
    color: #e5e5e5;
    min-height: 20px;
}

#gridModeContainer QSpinBox:hover {
    border: 2px solid #505050;
    background: #1f1f1f;
}

#gridModeContainer QSpinBox:focus {
    border: 2px solid #5B7FFF;
    background: #1a1a1a;
    outline: none;
}

#gridModeContainer QSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 30px;
    height: 20px;
    border-left-width: 1px;
    border-left-color: #3a3a3a;
    border-left-style: solid;
    border-top-right-radius: 10px;
    background: transparent;
    margin: 2px 2px 1px 1px;
}

#gridModeContainer QSpinBox::up-button:hover {
    background: rgba(90, 90, 90, 0.3);
}

#gridModeContainer QSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 30px;
    height: 20px;
    border-left-width: 1px;
    border-top-width: 1px;
    border-top-color: #3a3a3a;
    border-top-style: solid;
    border-left-color: #3a3a3a;
    border-left-style: solid;
    border-bottom-right-radius: 10px;
    background: transparent;
    margin: 1px 2px 2px 1px;
}

#gridModeContainer QSpinBox::down-button:hover {
    background: rgba(90, 90, 90, 0.3);
}

/* ============================================
   网格模式 - QComboBox 样式
   ============================================ */
#gridModeContainer QComboBox {
    border: none;
    border-radius: 12px;
    padding: 10px 15px;
    background: #1a1a1a;
    font-size: 14px;
    font-weight: 500;
    color: #e5e5e5;
    min-height: 20px;
}

#gridModeContainer QComboBox:hover {
    border: none;
    background: #1f1f1f;
}

#gridModeContainer QComboBox:focus {
    border: none;
    background: #1a1a1a;
    outline: none;
}

#gridModeContainer QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 30px;
    border-left-width: 0px;
    border-left-style: none;
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
    background: transparent;
}

#gridModeContainer QComboBox::drop-down:hover {
    background: rgba(90, 90, 90, 0.3);
}

#gridModeContainer QComboBox QAbstractItemView {
    background-color: #2d2d2d;
    border: none;
    border-radius: 8px;
    selection-background-color: #2d4a7c;
    selection-color: #e5e5e5;
    color: #e5e5e5;
    padding: 4px;
}

#gridModeContainer QComboBox QAbstractItemView::item {
    padding: 8px 12px;
    border-radius: 4px;
}

#gridModeContainer QComboBox QAbstractItemView::item:selected {
    background: #2d4a7c;
}

#gridModeContainer QComboBox QAbstractItemView::item:hover {
    background: #3a3a3a;
}

/* ============================================
   网格模式 - QTextEdit 样式
   ============================================ */
#gridModeContainer QTextEdit {
    border: 2px solid #404040;
    border-radius: 12px;
    padding: 12px;
    background: #1a1a1a;
    font-size: 14px;
    color: #e5e5e5;
}

#gridModeContainer QTextEdit:hover {
    border: 2px solid #505050;
}

#gridModeContainer QTextEdit:focus {
    border: 2px solid #5B7FFF;
    background: #1a1a1a;
    outline: none;
}

/* ============================================
   网格模式 - 左右侧面板样式
   已移至 base_dark.qss 统一管理
   ============================================ */

/* ============================================
   网格模式 - 卡片样式
   ============================================ */
#gridModeContainer ModernCard {
    background: #2d2d2d !important;
    border: 1px solid #3a3a3a !important;
    border-radius: 20px;
}

/* ============================================
   网格模式 - 标签文字颜色
   ============================================ */
#gridModeContainer QLabel {
    color: #90a1b9;
}

/* ============================================
   网格模式 - 按钮样式
   ============================================ */

/* 开始生成按钮 - 紫蓝渐变带投影 */
#gridModeContainer QPushButton#generateBtn {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 {{GRADIENT_START}}, stop:1 {{GRADIENT_END}});
    color: white;
    border: none;
    border-radius: 24px;
    font-size: 18px;
    font-weight: 600;
    padding: 16px 28px;
    margin: 8px;
}

#gridModeContainer QPushButton#generateBtn:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 {{GRADIENT_HOVER_START}}, stop:1 {{GRADIENT_HOVER_END}});
}

#gridModeContainer QPushButton#generateBtn:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 {{GRADIENT_PRESSED_START}}, stop:1 {{GRADIENT_PRESSED_END}});
}

#gridModeContainer QPushButton#generateBtn:disabled {
    background: #3a3a3a;
    color: #606060;
    margin: 8px;
}

#gridModeContainer ModernButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 {{GRADIENT_START}}, stop:1 {{GRADIENT_END}});
    color: white;
}

#gridModeContainer ModernButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 {{GRADIENT_HOVER_START}}, stop:1 {{GRADIENT_HOVER_END}});
}

#gridModeContainer ModernButton:disabled {
    background: #3a3a3a;
    color: #606060;
}

/* API配置按钮样式 - 编辑配置、查询余量等 */
#gridModeContainer QPushButton#expandBtn,
#gridModeContainer QPushButton#usageBtn,
#gridModeContainer QPushButton#saveBtn,
#gridModeContainer QPushButton#clearBtn,
#gridModeContainer QPushButton#toggleBtn {
    background-color: #353535;
    border: 2px solid #353535;
    border-radius: 8px;
    color: #cad5e2;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 16px;
}

#gridModeContainer QPushButton#expandBtn:hover,
#gridModeContainer QPushButton#usageBtn:hover,
#gridModeContainer QPushButton#saveBtn:hover,
#gridModeContainer QPushButton#clearBtn:hover,
#gridModeContainer QPushButton#toggleBtn:hover {
    background-color: #404040;
    border-color: #404040;
    color: #e5e5e5;
}

#gridModeContainer QPushButton#expandBtn:pressed,
#gridModeContainer QPushButton#usageBtn:pressed,
#gridModeContainer QPushButton#saveBtn:pressed,
#gridModeContainer QPushButton#clearBtn:pressed,
#gridModeContainer QPushButton#toggleBtn:pressed {
    background-color: #2d2d2d;
    border-color: #2d2d2d;
}

/* ============================================
   网格模式 - 图像标签和按钮样式
   ============================================ */

/* 标签容器不应用imageGrid的边框样式 */
#gridModeContainer QWidget#imageGrid QWidget#labelContainer {
    background: transparent !important;
    border: none !important;
    border-radius: 0px !important;
    padding: 0px;
    min-height: 36px;  /* 确保容器高度足够显示按钮 */
}

/* 图像索引标签样式 - 暗色主题 */
#gridModeContainer QLabel#imageIndexLabel {
    background: rgba(45, 45, 45, 0.95);
    color: #e5e5e5;
    font-size: 13px;
    font-weight: 600;
    padding:4px;
    border-radius: 6px;
    border: none;
    min-width: 26px;
    min-height: 26px;
    max-height: 26px;
}

/* 添加到上传区按钮样式 - 使用主按钮渐变 */
#gridModeContainer QPushButton#addToUploadBtn {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 {{GRADIENT_START}}, stop:1 {{GRADIENT_END}});
    color: white;
    border: none;
    border-radius: 6px;
    padding: 5px;
    width: 30px;
    height: 30px;
}

#gridModeContainer QPushButton#addToUploadBtn:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 {{GRADIENT_HOVER_START}}, stop:1 {{GRADIENT_HOVER_END}});
}

#gridModeContainer QPushButton#addToUploadBtn:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 {{GRADIENT_PRESSED_START}}, stop:1 {{GRADIENT_PRESSED_END}});
}

/* 下载图片按钮样式 - 使用更具体的选择器 */
#gridModeContainer QPushButton#presetBtn {
    background-color: #353535 !important;
    border: none !important;
    border-radius: 6px !important;
    padding: 4px;
    min-width: 26px;
    min-height: 26px;
}

#gridModeContainer QPushButton#presetBtn:hover {
    background-color: #404040 !important;
}

#gridModeContainer QPushButton#presetBtn:pressed {
    background-color: #2d2d2d !important;
}

#gridModeContainer QWidget#imageInfo {
    border-top: none;
}

#gridModeContainer QWidget#imageInfo QPushButton {
    background: #353535;
    color: #cad5e2;
    border: 1px solid #404040;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    padding: 10px 20px;
    min-height: 24px;
}

#gridModeContainer QWidget#imageInfo QPushButton:hover {
    background: #404040;
    border: 1px solid #505050;
    color: #e5e5e5;
}

#gridModeContainer QWidget#imageInfo QPushButton:pressed {
    background: #2d2d2d;
    border: 1px solid #353535;
}
