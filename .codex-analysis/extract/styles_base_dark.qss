}

/* 提示词工具栏按钮样式 - 添加、编辑、删除（仅图标） */
QPushButton#presetBtn {
    background-color: #3A3A3A !important;
    border: none !important;
    border-radius: 6px !important;
    min-width: 30px;
    min-height: 30px;
    max-width: 30px;
    max-height: 30px;
