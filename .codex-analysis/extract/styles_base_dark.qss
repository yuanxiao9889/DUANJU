}

QPushButton#expandBtn:pressed,
QPushButton#saveBtn:pressed,
QPushButton#clearBtn:pressed,
QPushButton#toggleBtn:pressed,
QPushButton#browsePromptFileBtn:pressed,
QPushButton#downloadTemplateBtn:pressed,
QPushButton#secondaryBtn:pressed {
