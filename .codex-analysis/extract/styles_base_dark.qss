}

/* 通用标签样式 */
QLabel {
    color: #999999;
    font-size: 13px;
}

/* API配置表单标签样式 */
QFormLayout QLabel {
    color: #A0A0A0;
    font-size: 13px;
}

/* 通用输入框样式 */
QLineEdit {
    border: 1px solid #3A3A3A;
    border-radius: 6px;
    padding: 8px 12px;
    background-color: #1A1A1A;
    font-size: 14px;
    color: #999999;
}

QLineEdit:hover {
    border-color: #505050;
}

QLineEdit:focus {
    border-color: #7B8CFF;
    background-color: #1A1A1A;
}

/* 通用文本编辑器样式 */
QTextEdit, QPlainTextEdit {
    border: 1px solid #3A3A3A;
    border-radius: 6px;
    padding: 8px;
    background-color: #1A1A1A;
    font-size: 14px;
    color: #999999;
}

QTextEdit:focus, QPlainTextEdit:focus {
    border-color: #7B8CFF;
    background-color: #1A1A1A;
}

/* 提示词输入框 - 加大字号 */
QTextEdit#promptInput {
    font-size: 16px;
    border: none;
}

QTextEdit#promptInput:focus {
    border: 2px solid #7a7a7a;
    background-color: #1A1A1A;
}

/* 通用下拉框样式 */
QComboBox {
    border: none;
    border-radius: 6px;
    padding: 8px 12px;
    background-color: #1A1A1A;
    font-size: 14px;
    color: #A0A0A0;
}

QComboBox:hover {
    border: none;
}

QComboBox:focus {
    border: none;
}

QComboBox::drop-down {
    border: none;
    width: 30px;
}

QComboBox::down-arrow {
    image: none;  /* 隐藏原始箭头，使用自定义SVG图标 */
    width: 0px;
    height: 0px;
}

/* ============================================
   下拉菜单优化样式 - 暗色模式
   ============================================ */
QComboBox QAbstractItemView {
    background-color: #1A1A1A;
    border: none;
    border-radius: 8px;
    padding: 4px;
    outline: none;
    color: #999999;
}

QComboBox QAbstractItemView::item {
    min-height: 40px;  /* 增加选项高度 */
    padding: 10px 12px;
    border-radius: 6px;  /* 圆角背景 */
    margin: 2px 4px;  /* 添加间距 */
    color: #999999;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #404040;  /* 悬停时深灰色背景 */
}

QComboBox QAbstractItemView::item:selected {
    background-color: #7B8CFF;  /* 选中时蓝色背景 */
    color: #ffffff;
    font-weight: 600;
}

/* 通用滚动条样式 */
QScrollBar:vertical {
    border: none;
    background-color: #1A1A1A;
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background-color: #3A3A3A;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background-color: #505050;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    border: none;
    background-color: #1A1A1A;
    height: 10px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    background-color: #3A3A3A;
    border-radius: 5px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #505050;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
}

/* 通用复选框样式 */
QCheckBox {
    spacing: 8px;
    font-size: 13px;
    color: #999999;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #3A3A3A;
    border-radius: 4px;
    background-color: #2B2B2B;
}

QCheckBox::indicator:hover {
    border-color: #7B8CFF;
}

QCheckBox::indicator:checked {
    background-color: #7B8CFF;
    border-color: #7B8CFF;
}

/* 通用单选按钮样式 */
QRadioButton {
    spacing: 8px;
    font-size: 13px;
    color: #999999;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #3A3A3A;
    border-radius: 9px;
    background-color: #2B2B2B;
}

QRadioButton::indicator:hover {
    border-color: #7B8CFF;
}

QRadioButton::indicator:checked {
    background-color: #7B8CFF;
    border-color: #7B8CFF;
}

/* 通用分组框样式 */
QGroupBox {
    border: 1px solid #3A3A3A;
    border-radius: 6px;
    margin-top: 12px;
    padding-top: 12px;
    font-size: 14px;
    font-weight: 500;
    color: #999999;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 8px;
    background-color: #1A1A1A;
}

/* 通用标签页样式 */
QTabWidget::pane {
    border: 1px solid #3A3A3A;
    border-radius: 6px;
    background-color: #2B2B2B;
}

QTabBar::tab {
    background-color: #3A3A3A;
    border: 1px solid #3A3A3A;
    border-bottom: none;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    padding: 8px 16px;
    margin-right: 2px;
    font-size: 13px;
    color: #808080;
}

QTabBar::tab:selected {
    background-color: #2B2B2B;
    color: #7B8CFF;
    font-weight: 500;
}

QTabBar::tab:hover {
    background-color: #2a2a2a;
}

/* 标签页图标间距 */
QTabBar::tab {
    padding-left: 12px;
    padding-right: 12px;
    icon-size: 20px;  /* 增大图标尺寸 */
}

QTabWidget::tab-bar {
    alignment: center;  /* 居中对齐 */
}

/* 通用进度条样式 */
QProgressBar {
    border: none;
    border-radius: 4px;
    background-color: #3A3A3A;
    text-align: center;
    height: 20px;
    color: #999999;
}

QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #e83ed5, stop:1 #fd952d);
    border-radius: 4px;
}

/* 通用滑块样式 */
QSlider::groove:horizontal {
    border: 1px solid #3A3A3A;
    height: 6px;
    background-color: #3A3A3A;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background-color: #7B8CFF;
    border: 1px solid #6A7AF0;
    width: 16px;
    margin: -6px 0;
    border-radius: 8px;
}

QSlider::handle:horizontal:hover {
    background-color: #6A7AF0;
}

/* 通用数字输入框样式 */
QSpinBox {
    border: 2px solid #3A3A3A;
    border-radius: 12px;
    padding: 10px 15px;
    background: #1A1A1A;
    font-size: 14px;
    font-weight: 500;
    color: #999999;
    min-height: 20px;
}

QSpinBox:hover {
    border: 2px solid #505050;
    background: #1f1f1f;
}

QSpinBox:focus {
    border: 2px solid #7B8CFF;
    background: #1A1A1A;
    outline: none;
}

QSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 30px;
    height: 20px;
    border-left-width: 1px;
    border-left-color: #3A3A3A;
    border-left-style: solid;
    border-top-right-radius: 10px;
    background: transparent;
    margin: 2px 2px 1px 1px;
}

QSpinBox::up-button:hover {
    background: rgba(90, 90, 90, 0.3);
}

QSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 30px;
    height: 20px;
    border-left-width: 1px;
    border-top-width: 1px;
    border-top-color: #3A3A3A;
    border-top-style: solid;
    border-left-color: #3A3A3A;
    border-left-style: solid;
    border-bottom-right-radius: 10px;
    background: transparent;
    margin: 1px 2px 2px 1px;
}

QSpinBox::down-button:hover {
    background: rgba(90, 90, 90, 0.3);
}

/* 工具提示 */
QToolTip {
    background-color: #2B2B2B;
    color: #999999;
    border: 1px solid #3A3A3A;
    border-radius: 4px;
    padding: 6px 10px;
    font-size: 12px;
}

/* 主题切换按钮 */
QPushButton#themeToggleBtn {
    background-color: transparent;
    border: none;
    border-radius: 18px;
    font-size: 20px;
    padding: 4px;
}

QPushButton#themeToggleBtn:hover {
    background-color: #3a3a3a;
}

QPushButton#themeToggleBtn:pressed {
    background-color: #404040;
}

/* ============================================
   网格模式 - 左右侧面板样式（暗色）
   ============================================ */

/* 左右侧面板样式已在文件顶部定义 */

/* 右侧面板内容 */
#textOutput {
    background: #252525;
    border: 1px solid #3a3a3a;
    border-radius: 12px;
    padding: 16px;
    color: #cad5e2;
}

#errorPlaceholder {
    background: #252525;
    border: 1px solid #3a3a3a;
    border-radius: 12px;
}

#emptyState {
    background: #2d2d2d;
    border-radius: 16px;
}

#imageGrid QWidget {
    background: #252525;
    border: none;
    border-radius: 0px;
}

#dragHint {
    background: rgba(91, 127, 255, 0.1);
    border: 2px dashed #e83ed5;
    border-radius: 16px;
}

/* 标签页组件样式 */
QTabWidget::pane {
    border: 1px solid #3a3a3a;
    border-radius: 8px;
    background: #2d2d2d;
    top: 0px;
    margin-top: 5px;
}

QTabWidget#mainProcessTabs {
    margin-left: -16px;
    margin-right: -16px;
    margin-top: 0px;
    margin-bottom: 0px;
    padding: 0px;
}

QTabWidget#mainProcessTabs::pane {
    border: 1px solid #3a3a3a;
    border-radius: 8px;
    background: #2d2d2d;
    top: 0px;
    margin-top: 5px;
}

QTabWidget#mainProcessTabs > QTabBar {
    width: 100%;
    min-width: 100%;
}

QWidget#singleProcessCard, QWidget#batchProcessCard {
    background: transparent;
}

QScrollArea#singleProcessScroll, QScrollArea#batchProcessScroll {
    background: transparent;
    border: none;
}

QWidget#singleProcessContent, QWidget#batchProcessContent {
    background: transparent;
}

/* mainProcessTabs 特定样式 - 使用更具体的选择器 */
QTabWidget#mainProcessTabs QTabBar::tab {
    background: transparent;
    border: none;
    border-radius: 8px;
    padding: 10px 16px;
    margin: 0px;
    min-height: 22px;
    font-size: 14px;
    font-weight: 500;
    color: #90a1b9;  /* 未选中颜色 */
    icon-size: 16px 16px;
}

QTabWidget#mainProcessTabs QTabBar {
    background: #000000;
    border-radius: 8px;
    padding: 5px;
    qproperty-drawBase: 0;
    width: 100%;
    min-width: 100%;
}

QTabWidget#mainProcessTabs::tab-bar {
    left: 0px;
    right: 0px;
    alignment: left;  /* 标签页居左对齐 */
}

QTabWidget#mainProcessTabs QTabBar::tab:selected {
    background: #404040;
    border: none;
    color: #ffffff;  /* 选中时白色 */
}

QTabWidget#mainProcessTabs QTabBar::tab:hover:!selected {
    background: rgba(64, 64, 64, 0.3);
    color: #a0b4d3;  /* 悬停时稍亮 */
}

/* 头部和标题样式 */
QLabel#leftHeader {
    padding: 16px 16px;
    background: transparent;
    border-bottom: 1px solid #3a3a3a;
    margin-left: 16px;
    margin-right: 16px;
    font-size: 18px;
    font-weight: 600;
    color: #90a1b9;
    line-height: 1.4;
}

QLabel#rightHeader {
    background: #2d2d2d !important;
    font-size: 20px;
    font-weight: bold;
    color: #cad5e2;
    padding: 40px 20px;
    text-align: center;
    border-bottom: 1px solid #3a3a3a;
    margin-left: 20px;
    margin-right: 20px;
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
}

/* 区域标题样式 */
QLabel#uploadSectionLabel {
    font-size: 16px;
    color: #77a1b9;
    margin-bottom: 8px;
    margin-top: 4px;
}

QLabel#uploadHint {
    color: #90a1b9;
    font-size: 15px;
}

QLabel#upload_info {
    color: #45556c;
    font-size: 13px;
}

QLabel#promptSectionLabel {
    font-size: 16px;
    color: #90a1b9;
    margin-bottom: 8px;
    margin-top: 4px;
}

QLabel#settingsSectionLabel {
    font-size: 16px;
    color: #e83ed5;
    margin-bottom: 8px;
    margin-top: 4px;
}

QLabel#cardTitle {
    color: #90a1b9;
    font-size: 15px;
}

/* 上传卡片 */
QWidget#uploadCard {
    background: #2d2d2d;
    border: 2px dashed #404040;
    border-radius: 5px;
    padding: 12px;
}

/* 批量处理日志容器样式 */
QScrollArea#batchLogScroll {
    background-color: #1a1a1a;
    border: none;
    border-radius: 8px;
}

QWidget#batchLogContainer {
    background-color: #1a1a1a;
    border: none;
}

/* 批量处理日志样式 */
QLabel#batchLogInfo {
    color: #b0b0b0;
    padding: 4px 8px;
    font-size: 13px;
}

QLabel#batchLogStart {
    color: #8b9dc3;
    padding: 4px 8px;
    font-size: 13px;
    font-weight: 500;
}

QLabel#batchLogSuccess {
    color: #4ade80;
    padding: 4px 8px;
    font-size: 13px;
}

QLabel#batchLogError {
    color: #f87171;
    padding: 4px 8px;
    font-size: 13px;
}

QLabel#batchLogProgress {
    color: #60a5fa;
    padding: 4px 8px;
    font-size: 13px;
}

QLabel#batchLogComplete {
    color: #fd952d;
    padding: 4px 8px;
    font-size: 13px;
    font-weight: 500;
}

QWidget#uploadCard:hover {
    background: #302538;
    border: 2px dashed #e83ed5;
}

/* 提示词卡片 */
QWidget#promptCard {
    background: #2d2d2d;
    border-radius: 5px;
    padding: 12px;
    margin: 8px;
}

/* 设置卡片 */
QWidget#settingsCard {
    background: #2d2d2d;
    border-radius: 5px;
    border: 1px solid #404040;
}

/* 批量处理模式提示标签 - 暗色模式 */
QLabel#fileModeHint,
QLabel#listModeHint {
    font-size: 13px;
    padding: 8px 12px;
    margin-top: 8px;  /* 顶部外间距 */
    background-color: #1e3a5f;  /* 深蓝色背景 */
    border: 1px solid #2d5a8a;  /* 中蓝色边框 */
    border-radius: 8px;
    font-weight: 400;
    /* 不修改文字颜色，使用默认的 #cad5e2 */
}

/* 批量缩略图样式 - 暗色模式 */
QLabel#batchThumbnail {
    border: 1px solid #404040;  /* 深色边框 */
    border-radius: 4px;
    background-color: #2a2a2a;  /* 深色背景 */
}

/* 文件命名建议提示 - 暗色模式 */
QLabel#fileNamingHint {
    font-size: 15px;
    padding: 8px 12px;
    margin-top: 4px;
    background-color: #1e3a5f;  /* 深蓝色背景 */
    border: 1px solid #2d5a8a;  /* 中蓝色边框 */
    border-radius: 6px;
    color: #93c5fd;  /* 浅蓝色文字 */
}
