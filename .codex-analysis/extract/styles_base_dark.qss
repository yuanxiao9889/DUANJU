/* ============================================
   暗色主题 - 基础样式
   颜色、字体、通用样式
   ============================================ */

/* 背景与主窗口 */
QMainWindow {
    background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, 
        stop:0 #1a1a1a, stop:0.3 #252525, stop:0.7 #2d2d2d, stop:1 #1e1e1e);
}

QWidget {
    font-family: "Microsoft YaHei UI", "Segoe UI", "Source Han Sans CN", "PingFang SC", ".AppleSystemUIFont", "WenQuanYi Micro Hei", sans-serif;
    color: #cad5e2;
}

/* 分割器样式 - 暗色主题 */
QSplitter::handle {
    background: #1a1a1a;
    border: none;
}

QSplitter::handle:horizontal {
    background: #1a1a1a;
    width: 8px;  /* 增加到 8px，更容易拖拽 */
    border: none;
    margin: 0px 2px;  /* 左右各留 2px 边距 */
}

QSplitter::handle:vertical {
    background: #1a1a1a;
    height: 8px;  /* 增加到 8px */
    border: none;
    margin: 2px 0px;  /* 上下各留 2px 边距 */
}

QSplitter::handle:hover {
    background: #3a3a3a;
}

QSplitter::handle:pressed {
    background: #4a4a4a;  /* 拖拽时更明显 */
}

/* 左右侧面板 - ModernCard 继承自 QFrame */
QFrame#leftPanel {
    background-color: #252525;
    border: none;
    border-radius: 0px;
    margin: 0px;
    padding: 0px;
}

QFrame#rightPanel {
    background-color: #1a1a1a;
    border: none;
    border-radius: 0px;
    margin: 0px;
    padding: 0px;
}

/* 左右侧面板内部的容器 QWidget 背景透明 */
/* 使用直接子选择器 > 只影响直接子元素 */
QFrame#leftPanel > QWidget,
QFrame#rightPanel > QWidget {
    background-color: transparent;
    border: none;
}

/* 滚动区域内的容器 */
QFrame#leftPanel QScrollArea > QWidget > QWidget,
QFrame#rightPanel QScrollArea > QWidget > QWidget {
    background-color: transparent;
}

/* 网格模式的滚动区域和内容容器 */
QScrollArea#bodyScroll {
    background: transparent;
    border: none;
}

QScrollArea#bodyScroll > QWidget > QWidget {
    background: #2d2d2d;
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
}

QWidget#bodyHost {
    background: #2d2d2d;
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
}

/* 通用按钮样式 */
QPushButton {
    background-color: #7B8CFF;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 14px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #6A7AF0;
}

QPushButton:pressed {
    background-color: #5969DE;
}

QPushButton:disabled {
    background-color: #3A3A3A;
    color: #A0A0A0;
}

/* 主窗口图标按钮（暗色）：默认透明，避免通用按钮蓝底 */
QPushButton#themeToggleBtn,
QPushButton#logBtn,
QPushButton#settingsBtn,
QPushButton#updateBtn,
QPushButton#modeSwitchThemeToggleBtn,
QPushButton#modeSwitchBackBtn {
    border: none;
    background: transparent;
    border-radius: 4px;
    color: #E5E7EB;
    padding: 0px;
}

QPushButton#themeToggleBtn:hover,
QPushButton#logBtn:hover,
QPushButton#settingsBtn:hover,
QPushButton#updateBtn:hover,
QPushButton#modeSwitchThemeToggleBtn:hover,
QPushButton#modeSwitchBackBtn:hover {
    background: rgba(255, 255, 255, 0.1);
}

QPushButton#themeToggleBtn:pressed,
QPushButton#logBtn:pressed,
QPushButton#settingsBtn:pressed,
QPushButton#updateBtn:pressed,
QPushButton#modeSwitchThemeToggleBtn:pressed,
QPushButton#modeSwitchBackBtn:pressed {
    background: rgba(255, 255, 255, 0.14);
}

QPushButton#themeToggleBtn:focus,
QPushButton#logBtn:focus,
QPushButton#settingsBtn:focus,
QPushButton#updateBtn:focus,
QPushButton#modeSwitchThemeToggleBtn:focus,
QPushButton#modeSwitchBackBtn:focus,
QPushButton#themeToggleBtn:checked,
QPushButton#logBtn:checked,
QPushButton#settingsBtn:checked,
QPushButton#updateBtn:checked,
QPushButton#modeSwitchThemeToggleBtn:checked,
QPushButton#modeSwitchBackBtn:checked {
    background: transparent;
}

/* 画布工具栏按钮基础样式（深色模式）*/
QPushButton#canvasToolbarButton {
    font-size: 15px;
}

/* 开始生成按钮 - 蓝紫渐变带投影 */
QPushButton#generateBtn {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #e83ed5, stop:1 #fd952d);
    color: white;
    border: none;
    border-radius: 24px;
    font-size: 16px;
    font-weight: 600;
    padding: 12px 24px;
    margin: 4px;  /* 留出投影显示区域 */
}

QPushButton#generateBtn:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #ed58dc, stop:1 #fda553);
}

QPushButton#generateBtn:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #d936c3, stop:1 #f1871f);
}

QPushButton#generateBtn:disabled {
    background: #3A3A3A;
    color: #A0A0A0;
    margin: 4px;  /* 留出投影显示区域 */
}

/* 打开目录按钮 - 与生成按钮相同的蓝紫渐变样式 */
QPushButton#openDirBtn {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #e83ed5, stop:1 #fd952d);
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 600;
    padding: 12px 24px;
    margin: 4px;
}

QPushButton#openDirBtn:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #ed58dc, stop:1 #fda553);
}

QPushButton#openDirBtn:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #d936c3, stop:1 #f1871f);
}

QPushButton#openDirBtn:disabled {
    background: #3A3A3A;
    color: #A0A0A0;
    margin: 4px;
}

/* 停止处理按钮 - 与生成按钮统一圆角 */
QPushButton#stopProcessBtn {
    background: #ef4444;
    color: white;
    border: none;
    border-radius: 24px;
    font-size: 14px;
    font-weight: 600;
}

QPushButton#stopProcessBtn:hover {
    background: #dc2626;
}

QPushButton#stopProcessBtn:pressed {
    background: #b91c1c;
}

QPushButton#stopProcessBtn:disabled {
    background: #3A3A3A;
    color: #A0A0A0;
}

/* API配置按钮样式 - 编辑配置、查询余量等 */
QPushButton#expandBtn,
QPushButton#saveBtn,
QPushButton#clearBtn,
QPushButton#toggleBtn,
QPushButton#browsePromptFileBtn,
QPushButton#downloadTemplateBtn,
QPushButton#secondaryBtn {
