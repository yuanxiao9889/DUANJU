{
  "name": "storyboard-copilot",
  "private": true,
  "version": "2.3.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:app": "npm run prepare:portable-git && npm run prepare:dreamina-cli && npm run build",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare:portable-git": "node scripts/prepare-portable-git.mjs",
    "prepare:dreamina-cli": "node scripts/prepare-dreamina-cli.mjs",
    "prepare:qwen3-tts-extension": "node scripts/prepare-qwen3-tts-extension.mjs",
    "prepare:voxcpm2-extension": "node scripts/prepare-voxcpm2-extension.mjs",
    "prepare:rmbg2-extension": "node scripts/prepare-rmbg2-extension.mjs",
    "prepare:seedvr2-extension": "node scripts/prepare-seedvr2-extension.mjs",
    "package:qwen3-tts-extension": "npm run prepare:qwen3-tts-extension && powershell -ExecutionPolicy Bypass -File scripts/package-qwen3-tts-extension.ps1",
    "package:voxcpm2-extension": "npm run prepare:voxcpm2-extension && powershell -ExecutionPolicy Bypass -File scripts/package-voxcpm2-extension.ps1",
    "package:rmbg2-extension": "npm run prepare:rmbg2-extension && powershell -ExecutionPolicy Bypass -File scripts/package-rmbg2-extension.ps1",
    "package:seedvr2-extension": "npm run prepare:seedvr2-extension && powershell -ExecutionPolicy Bypass -File scripts/package-seedvr2-extension.ps1",
    "test:dreamina-setup": "npm run prepare:portable-git && npm run prepare:dreamina-cli && node scripts/test-dreamina-setup.mjs",
    "sync:version": "node scripts/sync-version.mjs",
    "release": "node scripts/release.mjs",
    "package:msi": "tauri build --bundles msi",
    "package:nsis": "tauri build --bundles nsis",
    "package:patch:msi": "node scripts/build-installer.mjs patch msi",
    "package:patch:nsis": "node scripts/build-installer.mjs patch nsis",
    "package:windows": "node scripts/package-windows.mjs --bump patch --bundle nsis"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.75.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.6.1",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@xyflow/react": "^12.5.0",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.0.4",
    "konva": "^9.3.22",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.11.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.6",
    "react-i18next": "^15.4.1",
    "react-image-crop": "^11.0.10",
    "react-konva": "^18.2.10",
    "react-markdown": "^10.1.0",
    "react-range": "^1.10.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.183.2",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.183.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.3",
    "vite": "^6.1.0"
  }
}
